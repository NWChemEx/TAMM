et lindep:n_dep 0
set basis "ao basis"

SCF
thresh 1.0e-6
tol2e 1.0e-10
singlet
rhf
maxiter 300
END

tce
ipccsd
#ccsd
freeze atomic
thresh 1.0d-3
2eorb
2emet 13
#split 2
tilesize 40
attilesize 45
maxiter 100
nroots 2
end

set tce:maxeorb 0.405

set tce:nts T
set tce:tceiop 2048
#set tce:writeint T
#set tce:writet  T
set tce:readint T
set tce:readt T

task tce energy



