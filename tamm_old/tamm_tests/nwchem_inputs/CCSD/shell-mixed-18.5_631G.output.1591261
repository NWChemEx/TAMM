et lindep:n_dep 0
set basis "ao basis"

SCF
thresh 1.0e-3
tol2e 1.0e-9
singlet
rhf
maxiter 300
END

tce
ipccsd
freeze atomic
thresh 1.0d-4
2eorb
2emet 13
tilesize 40
attilesize 45
maxiter 100
nroots 2
end

set tce:maxeorb 0.43

set tce:nts T
set tce:tceiop 2048
set tce:writeint T
set tce:writet  T
#set tce:readint T
#set tce:readt T

task tce energy



